FROM ghcr.io/processone/ejabberd:latest

USER root

RUN apk add --no-cache curl openssl \
    && mkdir -p /opt/acme.sh && chown ejabberd:ejabberd /opt/acme.sh \
    && mkdir -p /etc/ejabberd && chown ejabberd:ejabberd /etc/ejabberd

USER ejabberd

RUN wget -O /tmp/acme.tar.gz https://github.com/acmesh-official/acme.sh/archive/master.tar.gz \
    && tar xzf /tmp/acme.tar.gz -C /opt/acme.sh --strip-components=1 \
    && rm /tmp/acme.tar.gz

COPY --chown=ejabberd:ejabberd ejabberd.yml /etc/ejabberd/ejabberd.yml
COPY --chown=ejabberd:ejabberd entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT []
CMD ["/usr/local/bin/entrypoint.sh"]
