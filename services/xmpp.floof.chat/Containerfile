FROM ghcr.io/processone/ejabberd:latest

USER root

RUN apk add --no-cache curl openssl \
    && mkdir -p /opt/acme.sh && chown ejabberd:ejabberd /opt/acme.sh \
    && cp -a /home/ejabberd/conf /etc/ejabberd && chown -R ejabberd:ejabberd /etc/ejabberd

USER ejabberd

# Download JS/CSS assets for mod_invites landing page.
RUN mkdir -p /home/ejabberd/share/jquery /home/ejabberd/share/bootstrap/js /home/ejabberd/share/bootstrap/css \
    && curl -sL -o /home/ejabberd/share/jquery/jquery.min.js \
       https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js \
    && curl -sL -o /home/ejabberd/share/bootstrap/js/bootstrap.bundle.min.js \
       https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js \
    && curl -sL -o /home/ejabberd/share/bootstrap/css/bootstrap.min.css \
       https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css

RUN curl https://get.acme.sh | sh -s -- email=lark@lark.gay \
    --home /opt/acme.sh \
    --nocron

COPY --chown=ejabberd:ejabberd ejabberd.yml /etc/ejabberd/ejabberd.yml
COPY --chown=ejabberd:ejabberd entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh

ENTRYPOINT []
CMD ["/usr/local/bin/entrypoint.sh"]
